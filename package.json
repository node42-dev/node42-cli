{
  "name": "@n42/cli",
  "version": "0.5.32",
  "description": "Node42 CLI — command-line interface for end-to-end Peppol eDelivery, diagnostics and tooling",
  "keywords": [
    "node42",
    "peppol",
    "edelivery",
    "diagnostics",
    "cli",
    "api"
  ],
  "homepage": "https://github.com/node42-dev/node42-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node42-dev/node42-cli.git"
  },
  "license": "AGPL-3.0-only OR LicenseRef-Commercial",
  "author": "Node42 @n42",
  "type": "module",
  "bin": {
    "n42": "./dist/n42.cjs"
  },
  "main": "./dist/n42.cjs",
  "scripts": {
    "lint": "eslint src",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov node --test test/*.test.js",
    "build": "esbuild src/cli.js --bundle --platform=node --format=cjs --outfile=dist/n42.cjs --define:import.meta.url=__filename --banner:js='#!/usr/bin/env node' && mkdir -p dist/assets dist/completion && cp -rf src/assets/* dist/assets && cp -rf src/completion/* dist/completion",
    "prepublishOnly": "npm run build"
  },
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "c8": {
    "exclude": [
      "src/cli/*",
      "src/completion/**"
    ]
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3",
    "@aws-sdk/credential-provider-ini": "^3",
    "@aws-sdk/lib-dynamodb": "^3"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@aws-sdk/credential-provider-ini": {
      "optional": true
    },
    "@aws-sdk/lib-dynamodb": {
      "optional": true
    }
  },
  "dependencies": {
    "@n42/cli": "^0.5.30",
    "@n42/edelivery": "^0.1.91",
    "commander": "^11.1.0",
    "dotenv": "^17.3.1",
    "inquirer": "^8.2.7",
    "open": "^11.0.0",
    "xmldom": "^0.6.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "esmock": "^2.7.3",
    "globals": "^17.4.0"
  }
}
