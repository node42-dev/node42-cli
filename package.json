{
  "name": "@n42/cli",
  "version": "0.4.91",
  "description": "Node42 CLI – Command-line interface for Peppol eDelivery path discovery, diagnostics, and tooling",
  "keywords": [
    "node42",
    "peppol",
    "edelivery",
    "diagnostics",
    "cli",
    "api"
  ],
  "homepage": "https://github.com/node42-dev/node42-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node42-dev/node42-cli.git"
  },
  "license": "MIT",
  "author": "Node42 @n42",
  "type": "module",
  "bin": {
    "n42": "./dist/n42.cjs"
  },
  "main": "./dist/n42.cjs",
  "scripts": {
    "lint": "eslint src",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov node --test test/*.test.js",
    "build": "esbuild src/cli.js --bundle --platform=node --format=cjs --outfile=dist/n42.cjs --define:import.meta.url=__filename --banner:js='#!/usr/bin/env node' && mkdir -p dist/assets dist/completion && cp -rf src/assets/* dist/assets && cp -rf src/completion/* dist/completion",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": "./dist/n42.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^8.2.7",
    "open": "^11.0.0",
    "xmldom": "^0.6.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "esmock": "^2.7.3",
    "globals": "^17.4.0",
    "sinon": "^21.0.1"
  }
}
